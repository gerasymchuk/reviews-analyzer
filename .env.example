# LLM provider: ollama, openai, anthropic, google
LLM_PROVIDER=ollama

# Model name
LLM_MODEL=kimi-k2.5:cloud

# Ollama cloud API URL
OLLAMA_URL=https://ollama.com/v1

# API keys
OLLAMA_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# iTunes RSS API parameters
DEFAULT_COUNTRY=us
MAX_REVIEWS=500

SAMPLE_SIZE=100