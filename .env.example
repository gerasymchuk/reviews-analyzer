# LLM provider: local, openai, anthropic etc
LLM_PROVIDER=local

# Model name
LLM_MODEL=llama3.1:latest

# Ollama URL
OLLAMA_URL=https://ollama.com/v1

# API keys
OLLAMA_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# iTunes RSS API parameters
DEFAULT_COUNTRY=us
MAX_REVIEWS=500

SAMPLE_SIZE=100